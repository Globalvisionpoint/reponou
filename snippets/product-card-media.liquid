<div class="media media--transparent media--{{ media_size }} media--hover-effect"
     {% if media_size == 'adapt' and product_card_product.featured_media %} style="padding-bottom: {{ 1 | divided_by: featured_media_aspect_ratio | times: 100 }}%;"{% endif %}
     >
  {%- liquid
      	assign second_img_position = product_card_product.featured_media.position
        assign second_img_position = second_img_position | plus: 1
      -%}
  <img
       srcset="{%- if product_card_product.featured_media.width >= 165 -%}{{ product_card_product.featured_media | image_url: width: 165, format: 'webp' }} 165w,{%- endif -%}
               {%- if product_card_product.featured_media.width >= 240 -%}{{ product_card_product.featured_media | image_url: width: 240, format: 'webp' }} 240w,{%- endif -%}
               {%- if product_card_product.featured_media.width >= 320 -%}{{ product_card_product.featured_media | image_url: width: 320, format: 'webp' }} 320w,{%- endif -%}
               {%- if product_card_product.featured_media.width >= 400 -%}{{ product_card_product.featured_media | image_url: width: 400, format: 'webp' }} 400w,{%- endif -%}
               {%- if product_card_product.featured_media.width >= 550 -%}{{ product_card_product.featured_media | image_url: width: 550, format: 'webp' }} 550w,{%- endif -%}
               {%- if product_card_product.featured_media.width >= 800 -%}{{ product_card_product.featured_media | image_url: width: 800, format: 'webp' }} 800w{%- endif -%}"
       src="{{ product_card_product.featured_media | image_url: width: 400, format: 'webp' }}"
       sizes="(min-width: {{ settings.container_lg_width }}px) {{ settings.container_lg_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
       alt="{{ product_card_product.featured_media.alt | escape }}"
       loading="lazy"
       class="motion-reduce"
       width="{{ product_card_product.featured_media.width }}"
       height="{{ product_card_product.featured_media.height }}"
       data-media-id="{{ section.id }}-{{ product_card_product.featured_media.id }}"
       >


  {%- if product_card_product.media[second_img_position] != nil and show_secondary_image -%}
  <img
       srcset="{%- if product_card_product.media[second_img_position].width >= 165 -%}{{ product_card_product.media[second_img_position] | image_url: width: 165, format: 'webp' }} 165w,{%- endif -%}
               {%- if product_card_product.media[second_img_position].width >= 240 -%}{{ product_card_product.media[second_img_position] | image_url: width: 240, format: 'webp' }} 240w,{%- endif -%}
               {%- if product_card_product.media[second_img_position].width >= 320 -%}{{ product_card_product.media[second_img_position] | image_url: width: 320, format: 'webp' }} 320w,{%- endif -%}
               {%- if product_card_product.media[second_img_position].width >= 400 -%}{{ product_card_product.media[second_img_position] | image_url: width: 400, format: 'webp' }} 400w,{%- endif -%}
               {%- if product_card_product.media[second_img_position].width >= 550 -%}{{ product_card_product.media[second_img_position] | image_url: width: 550, format: 'webp' }} 550w,{%- endif -%}
               {%- if product_card_product.media[second_img_position].width >= 800 -%}{{ product_card_product.media[second_img_position] | image_url: width: 800, format: 'webp' }} 800w{%- endif -%}"
       src="{{ product_card_product.media[second_img_position] | image_url: width: 400, format: 'webp' }}"
       sizes="(min-width: {{ settings.container_lg_width }}px) {{ settings.container_lg_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
       alt="{{ product_card_product.media[second_img_position].alt | escape }}"
       loading="lazy"
       class="motion-reduce secondary__img"
       width="{{ product_card_product.media[second_img_position].width }}"
       height="{{ product_card_product.media[second_img_position].height }}"
       data-media-id="{{ section.id }}-{{ product_card_product.media[second_img_position].id }}"
       >
  {%- endif -%}
</div>