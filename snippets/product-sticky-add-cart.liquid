{% liquid
  assign theme_rtl = false
  if settings.enable_rtl and settings.langauges_rtl == blank
    assign theme_rtl = true
  endif

  if settings.enable_rtl and settings.langauges_rtl != blank
    assign rtl_languages = settings.langauges_rtl | split: ','
    for language in rtl_languages
      if language == request.locale.iso_code
        assign theme_rtl = true
      endif
    endfor
  endif
%}

<style>
  .product__sticky {
    position: fixed;
    left: 0;
    right: 0;
    bottom: calc(var(--mobile-navigation-bar-height, 0px) + env(safe-area-inset-bottom, 0px));
    z-index: 98;
    padding: 0.8rem 1rem;
    background: rgba(255, 255, 255, 0.98);
    border-top: 1px solid rgba(18, 18, 18, 0.08);
    box-shadow: 0 -8px 24px rgba(0, 0, 0, 0.14);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s ease;
    transform: translateY(100%);
  }

  .product__sticky.sticky {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .product-form__buttons.sticky__form_button {
    width: 100%;
    margin: 0 !important;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0;
  }

  .product__sticky_head {
    display: none;
  }

  .product__sticky_add__form {
    width: 100%;
    gap: 0.9rem;
  }

  .product__sticky_add__form .product-form,
  .product__sticky_add__form .form {
    width: 100%;
  }

  .product__sticky_price {
    flex: 0 0 auto;
    min-width: max-content;
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
    color: #c91f39;
    white-space: nowrap;
  }

  sticky-variant-select.product__sticky_variant {
    display: none;
    width: 100%;
    margin-bottom: 0;
  }

  sticky-variant-select .select {
    position: relative;
  }

  sticky-variant-select .select_box {
    width: 100%;
    min-width: 0;
    height: 4.4rem;
    padding: 0 3.4rem 0 1.2rem;
    border-radius: 1.2rem;
    border: 1px solid rgba(18, 18, 18, 0.12);
    background: #ffffff;
  }

  .product__sticky_add__form quantity-input.quantity {
    flex: 0 0 9.6rem;
    min-width: 9.6rem;
    height: 4.8rem;
    margin-right: 0;
    border: 1px solid rgba(18, 18, 18, 0.12);
    border-radius: 1.3rem;
    background: #ffffff;
    box-shadow: none;
    overflow: hidden;
  }

  .product__sticky_add__form .quantity__button {
    width: 3rem;
    color: #222222;
    background: transparent;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .product__sticky_add__form .quantity__button:hover {
    background: rgba(217, 45, 47, 0.08);
    color: #c91f39;
  }

  .product__sticky_add__form .quantity__input {
    font-size: 1.5rem;
    font-weight: 600;
    color: #222222;
  }

  .product__sticky_add__form .product-form {
    flex: 1 1 auto;
    min-width: 0;
  }

  .product__sticky_add__form .product__add__cart__button,
  .product__sticky_add__form .product__add__cart__button.mr-20 {
    flex: 0 1 21rem;
    max-width: 21rem;
    width: auto;
    margin-right: 0;
    margin-left: auto;
  }

  .product__sticky_add__form .product__add__cart__button .button {
    width: 100%;
    min-height: 4.8rem;
    padding: 0 !important;
    border: 0 !important;
    border-radius: 1.3rem;
    background: linear-gradient(135deg, #c91f39 0%, #d92d2f 100%) !important;
    color: #ffffff !important;
    display: inline-flex;
    align-items: stretch;
    justify-content: flex-start;
    overflow: hidden;
    font-family: var(--font-heading-family);
    box-shadow: 0 10px 20px rgba(217, 45, 47, 0.16);
  }

  .product__sticky_add__form .product__add__cart__button .action__btn--svg {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 4.6rem;
    align-self: stretch;
    background: #bf1835;
    color: #ffffff;
  }

  .product__sticky_add__form .product__add__cart__button .action__btn--svg svg {
    width: 2rem;
    height: 2rem;
  }

  .product__sticky_add__form .product__add__cart__button .cart--button-text {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 1 1 auto;
    padding: 0 0.9rem;
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.1;
    text-align: center;
    text-transform: uppercase;
    white-space: nowrap;
    background: #d92d2f;
  }

  .product__sticky_add__form .shopify-payment-button {
    display: none !important;
  }

  @media only screen and (min-width: 992px) {
    .product__sticky {
      display: none !important;
    }

    body.sticky__cart {
      padding-bottom: 0 !important;
    }
  }

  @media only screen and (max-width: 991px) {
    body.sticky__cart {
      padding-bottom: calc(8.6rem + var(--mobile-navigation-bar-height, 0px));
    }
  }

  @media only screen and (max-width: 479px) {
    .product__sticky {
      padding: 0.7rem 0.8rem;
    }

    .product-form__buttons.sticky__form_button {
      gap: 0;
    }

    .product__sticky_add__form {
      gap: 0.7rem;
    }

    .product__sticky_add__form quantity-input.quantity {
      flex-basis: 7.8rem;
      min-width: 7.8rem;
    }

    .product__sticky_price {
      font-size: 1.52rem;
    }

    .product__sticky_add__form .product__add__cart__button,
    .product__sticky_add__form .product__add__cart__button.mr-20 {
      flex: 0 1 16rem;
      max-width: 16rem;
    }

    .product__sticky_add__form .product__add__cart__button .button {
      min-height: 4.3rem;
    }

    .product__sticky_add__form .product__add__cart__button .action__btn--svg {
      flex-basis: 3.2rem;
    }

    .product__sticky_add__form .product__add__cart__button .cart--button-text {
      font-size: 0.82rem;
      padding: 0 0.35rem;
      white-space: normal;
      line-height: 1.05;
    }

    .product__sticky_add__form .product__add__cart__button .button {
      min-height: 4.8rem;
    }

    .product__sticky_add__form .product__add__cart__button .action__btn--svg {
      flex-basis: 3.8rem;
    }

    .product__sticky_add__form .product__add__cart__button .cart--button-text {
      font-size: 1rem;
      padding: 0 0.8rem;
    }
  }

  {% if theme_rtl %}
    .product-form__buttons.sticky__form_button {
      flex-direction: row-reverse;
    }
  {% endif %}
</style>
<script src="{{ 'product-sticky-cart.js' | asset_url }}" defer="defer"></script>
{%- assign product_form_id = 'product-sticky-form-' | append: section.id -%}
<div class="product__sticky d-flex align-items-center justify-content-center {% if product.has_only_default_variant %}sticky__box_width{% endif %}">
  <div class="product__sticky_head d-flex align-items-center {% unless product.has_only_default_variant %}d-md-none{% endunless %}">
    <div class="sticky_pro_img">
      <img
        src="{{ product.featured_image | image_url: width: 120 }}"
        alt="{{ product.featured_image.alt | escape }}"
        width="60"
        height="{{ 60 | divided_by: product.featured_image.aspect_ratio | ceil }}"
        loading="lazy"
      >
    </div>
    <div class="sticky__proudct_title">
      {{ product.title }}
      {%- if product.has_only_default_variant -%}
        <p>{{ product.price | money }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- unless product.has_only_default_variant -%}
    <sticky-variant-select class="product__sticky_variant" data-section="{{ section.id }}">
      <div class="select">
        <select
          id="sticky__variant"
          class="select_box"
          name="options[]"
          form="product-sticky-form-{{ section.id }}"
        >
          {%- for variant in product.variants -%}
            <option
              value="{{ variant.id }}"
              {% if variant.available == false %}
                disabled="disabled"
              {% endif %}
            >
              {{ variant.title }} - {{ variant.price | money }}
            </option>
          {%- endfor -%}
        </select>
        {% render 'icon-caret' %}
      </div>
    </sticky-variant-select>
  {%- endunless -%}
  <div class="product__sticky_add__form d-flex align-items-center">
    <quantity-input class="quantity mr-20">
      <button class="quantity__button no-js-hidden" name="minus" type="button">
        <span class="visually-hidden">
          {{- 'products.product.quantity.decrease' | t: product: product.title | escape -}}
        </span>
        {% render 'icon-minus' %}
      </button>
      <input
        class="quantity__input"
        type="number"
        name="quantity"
        id="Sticky-Quantity-{{ section.id }}"
        min="1"
        value="1"
        form="product-sticky-form-{{ section.id }}"
      >
      <button class="quantity__button no-js-hidden" name="plus" type="button">
        <span class="visually-hidden">
          {{- 'products.product.quantity.increase' | t: product: product.title | escape -}}
        </span>
        {% render 'icon-plus' %}
      </button>
    </quantity-input>
    <div class="product__sticky_price">
      <span class="product__sticky_price-value">{{ current_variant.price | money }}</span>
    </div>
    <product-form class="product-form">
      {%- form 'product',
        product,
        id: product_form_id,
        class: 'form',
        novalidate: 'novalidate',
        data-type: 'add-to-cart-form'
      -%}
        <input id="sticky__selected_variant_id" type="hidden" name="id" value="{{ current_variant.id }}">
        <div class="product-form__buttons sticky__form_button d-flex">
          <div class="product__add__cart__button mr-20">
            <button
              type="submit"
              name="add"
              class="button button--primary"
              {% if current_variant.available == false and product.has_only_default_variant %}
                disabled
              {% endif %}
            >
              {%- if current_variant.available == false and product.has_only_default_variant -%}
                <span class="cart--button-text">{{ 'products.product.sold_out' | t }}</span>
              {%- else -%}
                <span class="action__btn--svg">{% render 'icon-cart', icon: 'cart' %}</span>
                <span class="cart--button-text">{{ 'products.product.add_to_cart' | t }}</span>
              {%- endif -%}
            </button>
          </div>
          <div class="d-sm-none">
            {{ form | payment_button }}
          </div>
        </div>
      {%- endform -%}
    </product-form>
  </div>
</div>
